-- Auto Steal Loop
task.spawn(function()
    while true do
        task.wait(Settings.Steal.Duration)
        if Settings.Steal.Enabled then
            Character = LocalPlayer.Character
            if not Character then continue end
            HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
            if not HumanoidRootPart then continue end

            -- Look for brainrot collectibles in workspace
            for _, obj in ipairs(workspace:GetDescendants()) do
                -- Brainrots are typically tagged or named parts you can collect
                -- Adjust the name filter to match actual collectible names in Brainrot Duels
                if obj:IsA("BasePart") or obj:IsA("Model") then
                    local targetPos
                    if obj:IsA("BasePart") then
                        targetPos = obj.Position
                    elseif obj:IsA("Model") and obj.PrimaryPart then
                        targetPos = obj.PrimaryPart.Position
                    end

                    if targetPos then
                        local dist = (HumanoidRootPart.Position - targetPos).Magnitude
                        if dist <= Settings.Steal.Radius then
                            -- Teleport to collect
                            HumanoidRootPart.CFrame = CFrame.new(targetPos)
                            task.wait(0.05)
                        end
                    end
                end
            end
        end
    end
end)

-- Bat Aimbot Loop
task.spawn(function()
    while true do
        task.wait(0.1)
        if Settings.BatAimbot.Enabled then
            Character = LocalPlayer.Character
            if not Character then continue end
            HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
            if not HumanoidRootPart then continue end

            local nearest = nil
            local nearestDist = Settings.BatAimbot.Radius

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local enemyHRP = player.Character:FindFirstChild("HumanoidRootPart")
                    if enemyHRP then
                        local dist = (HumanoidRootPart.Position - enemyHRP.Position).Magnitude
                        if dist < nearestDist then
                            nearestDist = dist
                            nearest = enemyHRP
                        end
                    end
                end
            end

            if nearest then
                -- Face the nearest enemy
                HumanoidRootPart.CFrame = CFrame.lookAt(HumanoidRootPart.Position, nearest.Position)
            end
        end
    end
end)

-- Anti Ragdoll + TP on Hit Logic
local function GetEnemyBase(side)
    -- Try to find the enemy base/spawn by side (Left or Right)
    -- Brainrot Duels typically has two bases, look for named folders/models
    local map = workspace:FindFirstChild("Map") or workspace:FindFirstChild("Arena") or workspace
    local bases = {}
    for _, obj in ipairs(map:GetChildren()) do
        if obj.Name:lower():find("base") or obj.Name:lower():find("spawn") or obj.Name:lower():find("team") then
            table.insert(bases, obj)
        end
    end
    if #bases >= 2 then
        table.sort(bases, function(a, b)
            local posA = a:IsA("Model") and a.PrimaryPart and a.PrimaryPart.Position.X or 0
            local posB = b:IsA("Model") and b.PrimaryPart and b.PrimaryPart.Position.X or 0
            return posA < posB
        end)
        -- Left = index 1, Right = index 2
        local idx = side == "Left" and 1 or 2
        local base = bases[idx]
        if base and base:IsA("Model") and base.PrimaryPart then
            return base.PrimaryPart.Position
        end
    end
    -- Fallback: estimate left/right from map center
    local centerX = 0
    if side == "Left" then
        return Vector3.new(centerX - 80, HumanoidRootPart.Position.Y, HumanoidRootPart.Position.Z)
    else
        return Vector3.new(centerX + 80, HumanoidRootPart.Position.Y, HumanoidRootPart.Position.Z)
    end
end

local function ApplyAntiRagdoll(char)
    if not char then return end
    for _, obj in ipairs(char:GetDescendants()) do
        -- Remove ragdoll constraints
        if obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") then
            obj.Enabled = false
        end
        -- Keep motor6Ds enabled
        if obj:IsA("Motor6D") then
            obj.Enabled = true
        end
    end
end

local function WatchForRagdoll(char)
    if not char then return end
    char.DescendantAdded:Connect(function(obj)
        if Settings.AntiRagdoll.Enabled then
            if obj:IsA("BallSocketConstraint") or obj:IsA("HingeConstraint") then
                task.wait()
                obj.Enabled = false
            end
        end
    end)

    -- Watch for Motor6D being disabled (ragdoll trigger)
    char.DescendantRemoving:Connect(function(obj) end)

    -- Continuously re-enable Motor6Ds when Anti Ragdoll is on
    task.spawn(function()
        while char and char.Parent do
            task.wait(0.1)
            if Settings.AntiRagdoll.Enabled then
                ApplyAntiRagdoll(char)
                -- If humanoid state becomes Physics (ragdoll), force back to running
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum:GetState() == Enum.HumanoidStateType.Physics then
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                    -- TP on Hit
                    if Settings.TPOnHit.Enabled then
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local targetPos = GetEnemyBase(Settings.TPOnHit.Side)
                            hrp.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
                        end
                    end
                end
            end
        end
    end)
end

-- Speed & Unwalk persistent check
LocalPlayer.CharacterAdded:Connect(function(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    HumanoidRootPart = char:WaitForChild("HumanoidRootPart")
    if Settings.Speed.Enabled then
        Humanoid.WalkSpeed = Settings.Speed.Value
    end
    if Settings.Unwalk.Enabled then
        Humanoid.WalkSpeed = 0
    end
    WatchForRagdoll(char)
end)

-- Apply to current character on load
WatchForRagdoll(Character)

